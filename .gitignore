```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.min.js
*.min.css
*.bundle.js

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```